{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Spring Boot (Debug)",
      "type": "shell",
      "command": "./run-local.sh --debug-jvm",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Listening for transport dt_socket at address: 5005.*",
            "endsPattern": "^.*Started BfMatchApplicationKt.*"
          }
        }
      ]
    }
  ]
}
