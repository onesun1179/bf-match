{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Attach Backend (Spring Boot)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "preLaunchTask": "Run Spring Boot (Debug)"
    },
    {
      "type": "node-terminal",
      "name": "Launch Frontend (Next.js)",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Launch Fullstack",
      "configurations": [
        "Attach Backend (Spring Boot)",
        "Launch Frontend (Next.js)"
      ]
    }
  ]
}